// The configuration file for your Skip App (https://skip.dev).
// Properties specified here are shared between
// Darwin/MVVMCSkipDemo.xcconfig and Android/settings.gradle.kts
// and will be included in the app's metadata files
// Info.plist and AndroidManifest.xml

// PRODUCT_NAME is the default title of the app, which must match the app's Swift module name
PRODUCT_NAME = MVVMCSkipDemo

// PRODUCT_BUNDLE_IDENTIFIER is the unique id for both the iOS and Android app
PRODUCT_BUNDLE_IDENTIFIER = com.joe.mvvmc.demo

// The semantic version of the app
MARKETING_VERSION = 0.0.1

// The build number specifying the internal app version
CURRENT_PROJECT_VERSION = 1

// The Kotlin package name used by Skip-generated Kotlin code (and by
// Android/app/src/main/kotlin/Main.kt's `package` line). Derived from the
// Swift module name, kept separate from the iOS bundle id below — Skip
// expects this to look like a Kotlin package, not an Apple bundle id.
ANDROID_PACKAGE_NAME = mvvmcskip.demo

// Android application id matches the iOS bundle id by default
// (ANDROID_APPLICATION_ID = PRODUCT_BUNDLE_IDENTIFIER). The explicit
// override below is included for clarity.
ANDROID_APPLICATION_ID = com.joe.mvvmc.demo
